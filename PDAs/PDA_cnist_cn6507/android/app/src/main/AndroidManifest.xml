<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 网络权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 访问网络状态权限 -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- 相机权限 -->
    <!-- 涉及扫码、拍照、录像 -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.BLUETOOTH" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.RtMobile"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".activities.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.RtMobile">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".activities.NetworkErrorActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.RtMobile" />
        <activity
            android:name=".activities.URLConfigActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.RtMobile" />
        <activity
            android:name=".activities.ScanningActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.RtMobile" />
        <activity
            android:name=".activities.WebViewActivity"
            android:clearTaskOnLaunch="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:excludeFromRecents="true"
            android:exported="false"
            android:label="@string/app_name"
            android:process=":main"
            android:theme="@style/Theme.RtMobile" />

        <!-- 禁用WebView的沙箱进程（工业设备必加） -->
        <meta-data
            android:name="android.webkit.WebView.MultiProcessDisabled"
            android:value="true" />
    </application>

</manifest>